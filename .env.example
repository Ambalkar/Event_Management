# Render Event Management System - Environment Variables
# Copy to .env and fill in values. Add to Render Dashboard.

# Database (use Render PostgreSQL Free Tier)
SPRING_DATASOURCE_URL=jdbc:postgresql://your-db-host:5432/event_ms_db
SPRING_DATASOURCE_USERNAME=your_db_user
SPRING_DATASOURCE_PASSWORD=your_db_password

# Spring Profile
SPRING_PROFILES_ACTIVE=production

# JPA / Hibernate
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

# Security (change defaults!)
SPRING_SECURITY_USERNAME=admin
SPRING_SECURITY_PASSWORD=your_secure_password

# App Config
SERVER_SERVLET_CONTEXT_PATH=/

# Logging (Render Free Tier)
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_EVENTMS=INFO

# Run schema setup manually:
# psql $SPRING_DATASOURCE_URL -f src/main/resources/postgres_schema.sql

